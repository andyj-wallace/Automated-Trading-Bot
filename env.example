# =============================================================================
# .env.example — Environment variable template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and must NEVER be committed.
# See environment-setup.md for documentation of every variable.
# =============================================================================

# --- Application ----------------------------------------------------------

# Runtime environment. Controls MockBroker vs IBKRClient and the live trading guard.
# Values: development | production
ENVIRONMENT=development

# Minimum log level for all application loggers.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Secret key for internal signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# --- Database -------------------------------------------------------------

# Async PostgreSQL connection string (asyncpg driver required).
# Default matches the Docker Compose service in docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading_bot

# --- Redis ----------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# --- IBKR / IB Gateway ----------------------------------------------------

# IB Gateway connection — always localhost for local development.
IBKR_HOST=127.0.0.1
IBKR_PORT=4001

# Client ID: unique integer per simultaneous Gateway connection.
# Use 1 for the main app, higher numbers (e.g. 99) for test scripts.
IBKR_CLIENT_ID=1

# Paper trading credentials.
# Not read by the FastAPI app directly — used by ib-gateway-docker for
# automated login in cloud deployment. See ibkr-gateway.md.
IBKR_USERNAME=
IBKR_PASSWORD=

# Trading mode. Must be 'paper' in development — enforced by IBKRClient.connect().
# ⚠️  Only set to 'live' in a production environment with real money intent.
# Values: paper | live
IBKR_TRADING_MODE=paper

# --- Notifications (Phase 3+) ---------------------------------------------

# SMTP connection string for email alerts. Leave empty until Phase 3.
# Format: smtp://user:password@host:port
NOTIFICATION_EMAIL_SMTP=

# --- VNC (cloud deployment only) ------------------------------------------

# Password for VNC access to the ib-gateway-docker container.
# Not needed for local development — leave empty.
VNC_PASSWORD=
